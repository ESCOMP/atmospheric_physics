  dimensions = (horizontal_loop_extent, maximum_number_of_convective_layers_in_eddy_diffusion)
  intent = in
[ wsed ]
  standard_name = sedimentation_velocity_of_liquid_stratus_cloud_droplet_at_top_of_convective_layer
