[ccpp-table-properties]
  name = uw_convect_shallow_diagnostics
  type = scheme

[ccpp-arg-table]
  name  = uw_convect_shallow_diagnostics_init
  type  = scheme
[ errmsg ]
  standard_name = ccpp_error_message
  units = none
  type = character | kind = len=512
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  units = 1
  type = integer
  dimensions = ()
  intent = out

[ccpp-arg-table]
  name  = uw_convect_shallow_diagnostics_run
  type  = scheme
[ ncol ]
