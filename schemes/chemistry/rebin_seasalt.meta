[ccpp-table-properties]
  name = rebin_seasalt
  type = scheme

[ccpp-arg-table]
  name  = rebin_seasalt_register
  type  = scheme
[ seasalt_constituents ]
  standard_name = dynamic_constituents_for_rebin_seasalt
  units = none
  type = ccpp_constituent_properties_t
  dimensions = (:)
  allocatable = True
  intent = out
[ errmsg ]
  standard_name = ccpp_error_message
  units = none
  type = character | kind = len=*
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  units = 1
  type = integer
  dimensions = ()
  intent = out

[ccpp-arg-table]
  name  = rebin_seasalt_init
  type  = scheme
[ amIRoot ]
  standard_name = flag_for_mpi_root
  units = flag
  type = logical
  dimensions = ()
  intent = in
[ iulog ]
  standard_name = log_output_unit
  units = 1
  type = integer
  dimensions = ()
  intent = in
[ pcnst ]
  standard_name = number_of_ccpp_constituents
  units = count
  type = integer
  dimensions = ()
  intent = in
[ const_props ]
  standard_name = ccpp_constituent_properties
  units = none
  type = ccpp_constituent_prop_ptr_t
  dimensions = (number_of_ccpp_constituents)
  intent = in
[ errmsg ]
  standard_name = ccpp_error_message
  units = none
  type = character | kind = len=*
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  units = 1
  type = integer
  dimensions = ()
  intent = out

[ccpp-arg-table]
  name  = rebin_seasalt_run
  type  = scheme
[ ncol ]
  standard_name = horizontal_loop_extent
  units = count
  type = integer
  dimensions = ()
  intent = in
[ pver ]
  standard_name = vertical_layer_dimension
  units = count
  type = integer
  dimensions = ()
  intent = in
[ pcnst ]
  standard_name = number_of_ccpp_constituents
  units = count
  type = integer
  dimensions = ()
  intent = in
[ constituents ]
  standard_name = ccpp_constituents
  units = none
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension, number_of_ccpp_constituents)
  intent = inout
[ errmsg ]
  standard_name = ccpp_error_message
  units = none
  type = character | kind = len=*
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  units = 1
  type = integer
  dimensions = ()
  intent = out
