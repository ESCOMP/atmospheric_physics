[ccpp-table-properties]
  name = bl_mynn_diagnostics
  type = scheme

[ccpp-arg-table]
  name = bl_mynn_diagnostics_init
  type = scheme
[ errmsg ]
  standard_name = ccpp_error_message
  long_name = Error message for error handling in CCPP
  units = none
  type = character | kind = len=*
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  long_name = Error flag for error handling in CCPP
  units = 1
  type = integer
  dimensions = ()
  intent = out

[ccpp-arg-table]
  name = bl_mynn_diagnostics_run
  type = scheme
[ qke ]
  standard_name = tke_multiplied_by_two
  units = m2 s-2
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qke_adv ]
  standard_name = tke_multiplied_by_two_due_to_advection
  units = m2 s-2
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ tsq ]
  standard_name = variance_of_liquid_water_potential_temperature
  units = K2
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qsq ]
  standard_name = variance_of_water_vapor_mixing_ratio_wrt_moist_air
  units = kg2 kg-2
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ cov ]
  standard_name = covariance_of_liquid_water_potential_temperature_and_water_vapor_mixing_ratio_wrt_moist_air
  units = K kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ pblh ]
  standard_name = atmosphere_boundary_layer_thickness
  units = m
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent)
  intent = in
[ el_pbl ]
  standard_name = turbulent_mixing_length
  units = m
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ sh ]
  standard_name = stability_function_for_heat
  units = 1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ sm ]
  standard_name = stability_function_for_momentum
  units = 1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qc_bl ]
  standard_name = subgrid_scale_cloud_liquid_water_mixing_ratio_wrt_moist_air
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qi_bl ]
  standard_name = subgrid_scale_cloud_ice_mixing_ratio_wrt_moist_air
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ cldfra_bl ]
  standard_name = subgrid_scale_cloud_area_fraction_in_atmosphere_layer
  units = fraction
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_a ]
  standard_name = updraft_area_fraction_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = fraction
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_w ]
  standard_name = updraft_vertical_velocity_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = m s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_qt ]
  standard_name = updraft_total_water_mixing_ratio_wrt_moist_air_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_thl ]
  standard_name = updraft_liquid_water_potential_temperature_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = K
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_ent ]
  standard_name = updraft_entrainment_rate_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = m-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_qc ]
  standard_name = updraft_cloud_liquid_water_mixing_ratio_wrt_moist_air_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ sub_thl ]
  standard_name = tendency_of_liquid_water_potential_temperature_due_to_subsidence_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = K s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ sub_sqv ]
  standard_name = tendency_of_water_vapor_mixing_ratio_wrt_moist_air_due_to_subsidence_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1 s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ det_thl ]
  standard_name = tendency_of_liquid_water_potential_temperature_due_to_detrainment_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = K s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ det_sqv ]
  standard_name = tendency_of_water_vapor_mixing_ratio_wrt_moist_air_due_to_detrainment_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1 s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_a_dd ]
  standard_name = downdraft_area_fraction_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = fraction
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_w_dd ]
  standard_name = downdraft_vertical_velocity_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = m s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_qt_dd ]
  standard_name = downdraft_total_water_mixing_ratio_wrt_moist_air_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_thl_dd ]
  standard_name = downdraft_liquid_water_potential_temperature_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = K
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_ent_dd ]
  standard_name = downdraft_entrainment_rate_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = m-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ edmf_qc_dd ]
  standard_name = downdraft_cloud_liquid_water_mixing_ratio_wrt_moist_air_in_scale_aware_tke_moist_edmf_pbl_scheme
  units = kg kg-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ exch_h ]
  standard_name = atmosphere_heat_diffusivity
  units = m2 s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ exch_m ]
  standard_name = atmosphere_momentum_diffusivity
  units = m2 s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ dqke ]
  standard_name = total_tendency_of_tke
  units = m2 s-3
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qwt ]
  standard_name = tendency_of_tke_due_to_vertical_transport
  units = m2 s-3
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qshear ]
  standard_name = tendency_of_tke_due_to_shear
  units = m2 s-3
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qbuoy ]
  standard_name = tendency_of_tke_due_to_buoyancy
  units = m2 s-3
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ qdiss ]
  standard_name = tendency_of_tke_due_to_dissipation
  units = m2 s-3
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  intent = in
[ maxwidth ]
  standard_name = maximum_plume_width_for_mynn_pbl_scheme
  units = m
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent)
  intent = in
[ maxmf ]
  standard_name = maximum_mass_flux_for_mynn_pbl_scheme
  units = m s-1
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent)
  intent = in
[ ztop_plume ]
  standard_name = height_of_highest_plume_for_mynn_pbl_scheme
  units = m
  type = real | kind = kind_phys
  dimensions = (horizontal_loop_extent)
  intent = in
[ errmsg ]
  standard_name = ccpp_error_message
  long_name = Error message for error handling in CCPP
  units = none
  type = character | kind = len=*
  dimensions = ()
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  long_name = Error flag for error handling in CCPP
  units = 1
  type = integer
  dimensions = ()
  intent = out
