@test
subroutine get_molar_mass_ratio_h2o()
    use funit
    use radiation_utils, only: get_molar_mass_ratio
    use ccpp_kinds,      only: kind_phys

    integer :: errflg
    real(kind_phys) :: mass_ratio
    character(len=512) :: errmsg

    call get_molar_mass_ratio('H2O', mass_ratio, errmsg, errflg)

    @assertEqual(0, errflg)
    @assertEqual('', errmsg)
    @assertEqual(1.607793_kind_phys, mass_ratio)
end subroutine get_molar_mass_ratio_h2o

