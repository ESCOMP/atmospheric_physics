@test
subroutine get_molar_mass_ratio_invalid()
    use funit
    use radiation_utils, only: get_molar_mass_ratio
    use ccpp_kinds,      only: kind_phys

    integer :: errflg
    real(kind_phys) :: mass_ratio
    character(len=512) :: errmsg

    call get_molar_mass_ratio('N2', mass_ratio, errmsg, errflg)

    @assertEqual(1, errflg)
    @assertEqual('get_molar_mass_ratio: Invalid gas: N2', errmsg)
end subroutine get_molar_mass_ratio_invalid
