    integer :: errflg

    omega(:) = 0.0001_kind_phys
    rearth = 6.371E6_kind_phys
    dx(:) = huge(0.0_kind_phys)

    call compute_characteristic_grid_length_scale_init( &
        omega, rearth, dx, &
        errmsg, errflg)

    ! Should compute characteristic grid length scale correctly.
    @assertEqual(6.371E4_kind_phys, dx, spacing(6.371E4_kind_phys))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)
end subroutine test_compute_characteristic_grid_length_scale_init

@test
subroutine test_compute_hydrostatic_upward_air_velocity_at_interface_run()
    use ccpp_kinds, only: kind_phys
    use funit
    use mmm_physics_compat, only: compute_hydrostatic_upward_air_velocity_at_interface_run

    integer, parameter :: ncol = 100, pver = 10, pverp = 11
    real(kind_phys) :: gravit, omega(ncol, pver), rho(ncol, pver)
    real(kind_phys) :: wint(ncol, pverp)
    character(100) :: errmsg
    integer :: errflg

    integer :: k
    real(kind_phys), parameter :: wint_expected(*, *) = spread([ &
        0.0_kind_phys, &
        0.75_kind_phys, &
        1.25_kind_phys, &
        1.75_kind_phys, &
        2.25_kind_phys, &
        2.75_kind_phys, &
        3.25_kind_phys, &
        3.75_kind_phys, &
        4.25_kind_phys, &
        4.75_kind_phys, &
        0.0_kind_phys], 1, ncol)

    gravit = 9.8_kind_phys
    rho(:, :) = 1.0_kind_phys

    do k = 1, pver
        omega(:, k) = -4.9_kind_phys * real(k, kind_phys)
    end do

    wint(:, :) = huge(0.0_kind_phys)

    call compute_hydrostatic_upward_air_velocity_at_interface_run( &
        gravit, omega, rho, &
        wint, &
        errmsg, errflg)

    ! Should compute hydrostatic upward air velocity at interface correctly.
    @assertEqual(wint_expected, wint, spacing(maxval(wint_expected)))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)

    do k = 1, pver
        omega(:, k) = 4.9_kind_phys * real(k, kind_phys)
    end do

    wint(:, :) = huge(0.0_kind_phys)

    call compute_hydrostatic_upward_air_velocity_at_interface_run( &
        gravit, omega, rho, &
        wint, &
        errmsg, errflg)

    ! Should compute hydrostatic upward air velocity at interface correctly.
    @assertEqual(-wint_expected, wint, spacing(maxval(wint_expected)))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)
end subroutine test_compute_hydrostatic_upward_air_velocity_at_interface_run

@test
subroutine test_compute_hydrostatic_upward_air_velocity_run()
    use ccpp_kinds, only: kind_phys
    use funit
    use mmm_physics_compat, only: compute_hydrostatic_upward_air_velocity_run

    integer, parameter :: ncol = 100, pver = 10
    real(kind_phys) :: gravit, omega(ncol, pver), rho(ncol, pver)
    real(kind_phys) :: wmid(ncol, pver)
    character(100) :: errmsg
    integer :: errflg

    gravit = 9.8_kind_phys
    rho(:, :) = 1.0_kind_phys

    omega(:, :) = -49.0_kind_phys
    wmid(:, :) = huge(0.0_kind_phys)

    call compute_hydrostatic_upward_air_velocity_run( &
        gravit, omega, rho, &
        wmid, &
        errmsg, errflg)

    ! Should compute hydrostatic upward air velocity correctly.
    @assertEqual(5.0_kind_phys, wmid, spacing(5.0_kind_phys))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)

    omega(:, :) = 49.0_kind_phys
    wmid(:, :) = huge(0.0_kind_phys)

    call compute_hydrostatic_upward_air_velocity_run( &
        gravit, omega, rho, &
        wmid, &
        errmsg, errflg)

    ! Should compute hydrostatic upward air velocity correctly.
    @assertEqual(-5.0_kind_phys, wmid, spacing(5.0_kind_phys))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)
end subroutine test_compute_hydrostatic_upward_air_velocity_run

@test
subroutine test_geopotential_height_wrt_sfc_at_interface_to_msl_run()
    use ccpp_kinds, only: kind_phys
    use funit
    use mmm_physics_compat, only: geopotential_height_wrt_sfc_at_interface_to_msl_run

    integer, parameter :: ncol = 100, pverp = 11
    real(kind_phys) :: gravit, phis(ncol), zisfc(ncol, pverp)
    real(kind_phys) :: zimsl(ncol, pverp)
    character(100) :: errmsg
    integer :: errflg

    gravit = 9.8_kind_phys
    phis(:) = 98.0_kind_phys
    zisfc(:, :) = 10.0_kind_phys
    zimsl(:, :) = huge(0.0_kind_phys)

    call geopotential_height_wrt_sfc_at_interface_to_msl_run( &
        ncol, &
        gravit, phis, zisfc, &
        zimsl, &
        errmsg, errflg)

    ! Should compute geopotential height wrt mean sea level at interface correctly.
    @assertEqual(20.0_kind_phys, zimsl, spacing(20.0_kind_phys))
    @assertEqual('', errmsg)
    @assertEqual(0, errflg)
end subroutine test_geopotential_height_wrt_sfc_at_interface_to_msl_run

