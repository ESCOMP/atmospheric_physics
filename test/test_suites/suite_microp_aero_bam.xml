<?xml version="1.0" encoding="UTF-8"?>

<suite name="microp_aero_bam" version="1.0">
  <group name="physics_after_coupler">
    <!--
      microp_aero - microphysics bindings to aerosol

      This is the BAM variant.
      Due to differences in aerosol activation between BAM and
      MAM/CARMA, the SDF for them is slightly different.

      ! NOTE hplin 4/7/26 4/17/26
      ! The scheme order in CAM-SIMA replacing microp_aero is:
      !   0.  chemical_tropopause
      !   1.  compute_subgrid_vertical_velocity (TKE or KVH variant)
      !   2.  scale_subgrid_vertical_velocity
      !   3.  nucleate_ice_ccpp           this scheme
      !   4a. dropmixnuc (MAM/CARMA)      future
      !   4b. ndrop_bam (BAM)             already done
      !   5.  contact_freezing_modal      future
      !   6.  hetfrz_classnuc_ccpp        future
    -->

    <!-- Helper to read all possible constituents from file -->
    <scheme>initialize_constituents</scheme>

    <!-- Register BAM aerosol pbuf fields as constituents for snapshot testing -->
    <scheme>initialize_pbuf_aerosols</scheme>

    <!-- Temporary initialization for to_be_ccppized: wv_saturation -->
    <scheme>to_be_ccppized_temporary</scheme>

    <!-- Rebin seasalt from 4bin prescribed (or snapshot) to 2bin -->
    <scheme>rebin_seasalt</scheme>

    <!-- Find chemical tropopause: -->
    <scheme>tropopause_find</scheme>

    <!--
      Compute and scale subgrid vertical velocity
      CAM7/CAM6: use the clubb variant that derives tke from WP2_nadv
      CAM5: UW uses the tke variant
      CAM4: HB uses the kvh variant
    -->
    <scheme>compute_subgrid_vertical_velocity_clubb</scheme>
    <scheme>scale_subgrid_vertical_velocity</scheme>
    <scheme>scale_subgrid_vertical_velocity_diagnostics</scheme>

    <!-- Set default dust size radii for microphysics -->
    <scheme>dust_default_radii</scheme>

    <!--
      Ice nucleation
      Runs even without aerosol models when microp_aero is active
      for Meyers 1992 deposition.
      Updates NAAI, NAAI_HOM etc. for PUMAS

      Has constituent tendencies only in MAM/CARMA
    -->
    <scheme>nucleate_ice_ccpp</scheme>
    <scheme>nucleate_ice_diagnostics</scheme>

    <!--
      Droplet activation (BAM)
      Computes npccn, nacon for microphysical schemes, ccn, naer2_diag for diag
    -->
    <scheme>ndrop_bam_ccpp</scheme>
    <scheme>ndrop_bam_diagnostics</scheme>

    <!-- Stub for hetfrz: used to pass the namelist option to other schemes
         since it alters behavior in other microphysical schemes. -->
    <scheme>hetfrz_classnuc_stub</scheme>
  </group>
</suite>
